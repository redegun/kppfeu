---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "KPPF.EU - Premium Paint Protection Film", description = "Premium paint protection film for the European market. Self-healing technology, chemical resistance, and deep gloss finish." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <title>{title}</title>
</head>
<body class="bg-kppf-black text-kppf-gray font-sans antialiased">
  <!-- Header -->
  <header class="bg-kppf-gray-800 border-b border-kppf-gray-700/50 sticky top-0 z-50 backdrop-blur-sm bg-kppf-gray-800/95">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <a href="/" class="text-2xl font-bold text-kppf-green hover:text-kppf-green-500 transition-all font-head tracking-wider">
          KPPF
        </a>
        
        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center space-x-1">
          <a href="/products" class="text-kppf-gray-300 hover:text-kppf-green px-4 py-2 rounded-lg text-sm font-medium transition-all hover:bg-kppf-gray-700/50">Products</a>
          <a href="/videos" class="text-kppf-gray-300 hover:text-kppf-green px-4 py-2 rounded-lg text-sm font-medium transition-all hover:bg-kppf-gray-700/50">Videos</a>
          <a href="/about" class="text-kppf-gray-300 hover:text-kppf-green px-4 py-2 rounded-lg text-sm font-medium transition-all hover:bg-kppf-gray-700/50">About</a>
          <a href="/contact" class="text-kppf-gray-300 hover:text-kppf-green px-4 py-2 rounded-lg text-sm font-medium transition-all hover:bg-kppf-gray-700/50">Contact</a>
          <a href="/cart" class="ml-2 bg-kppf-green hover:bg-kppf-green-500 text-kppf-black px-4 py-2 rounded-lg text-sm font-semibold transition-all flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
            </svg>
            Cart
            <span id="cart-count" class="bg-kppf-black text-kppf-green text-xs rounded-full h-5 w-5 flex items-center justify-center font-bold">0</span>
          </a>
        </div>
        
        <!-- Mobile menu button -->
        <button id="mobile-menu-button" class="md:hidden text-kppf-gray-400 hover:text-kppf-green p-2 rounded-lg transition-colors">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      
      <!-- Mobile Nav -->
      <div id="mobile-menu" class="md:hidden hidden pb-4">
        <div class="space-y-1 bg-kppf-gray-700 rounded-xl p-3 mt-2">
          <a href="/products" class="block text-kppf-gray-200 hover:text-kppf-green hover:bg-kppf-gray-600 px-4 py-3 rounded-lg transition-all">Products</a>
          <a href="/videos" class="block text-kppf-gray-200 hover:text-kppf-green hover:bg-kppf-gray-600 px-4 py-3 rounded-lg transition-all">Videos</a>
          <a href="/about" class="block text-kppf-gray-200 hover:text-kppf-green hover:bg-kppf-gray-600 px-4 py-3 rounded-lg transition-all">About</a>
          <a href="/contact" class="block text-kppf-gray-200 hover:text-kppf-green hover:bg-kppf-gray-600 px-4 py-3 rounded-lg transition-all">Contact</a>
          <a href="/cart" class="block bg-kppf-green text-kppf-black font-semibold px-4 py-3 rounded-lg text-center mt-2">
            Cart (<span id="mobile-cart-count">0</span>)
          </a>
        </div>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-kppf-black-500 border-t border-kppf-gray-700/30">
    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <h3 class="text-xl font-bold text-kppf-green font-head tracking-wider mb-4">KPPF</h3>
          <p class="text-kppf-gray-400 text-sm leading-relaxed">Premium paint protection film for the European market. Professional quality, European support.</p>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-kppf-gray-200 uppercase tracking-wider mb-4">Contact</h4>
          <div class="space-y-3 text-kppf-gray-400 text-sm">
            <p>Drottninggatan 55, 111 21 Stockholm, Sweden</p>
            <p><a href="mailto:info@kppf.eu" class="hover:text-kppf-green transition-colors">info@kppf.eu</a></p>
            <p><a href="tel:+4681234567" class="hover:text-kppf-green transition-colors">+46 8 123 45 67</a></p>
          </div>
        </div>
        <div>
          <h4 class="text-sm font-semibold text-kppf-gray-200 uppercase tracking-wider mb-4">Navigation</h4>
          <div class="space-y-2">
            <a href="/products" class="block text-kppf-gray-400 hover:text-kppf-green text-sm transition-colors">Products</a>
            <a href="/videos" class="block text-kppf-gray-400 hover:text-kppf-green text-sm transition-colors">Videos</a>
            <a href="/about" class="block text-kppf-gray-400 hover:text-kppf-green text-sm transition-colors">About</a>
            <a href="/contact" class="block text-kppf-gray-400 hover:text-kppf-green text-sm transition-colors">Contact</a>
          </div>
        </div>
      </div>
      <div class="mt-10 pt-8 border-t border-kppf-gray-700/30 text-center text-kppf-gray-500 text-sm">
        <p>&copy; 2026 KPPF Europe. All rights reserved.</p>
      </div>
    </div>
  </footer>
  
  <script>
    document.getElementById('mobile-menu-button')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
    
    function updateCartCount() {
      const cart = JSON.parse(localStorage.getItem('kppf-cart') || '[]');
      const count = cart.reduce((sum: number, item: any) => sum + item.quantity, 0);
      const el = document.getElementById('cart-count');
      const mel = document.getElementById('mobile-cart-count');
      if (el) el.textContent = count.toString();
      if (mel) mel.textContent = count.toString();
    }
    updateCartCount();
    window.addEventListener('storage', updateCartCount);
    window.addEventListener('cart-updated', updateCartCount);
  </script>
</body>
</html>
