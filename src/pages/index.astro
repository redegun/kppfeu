---
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  { icon: "✦", title: "Self-Healing", desc: "Scratches disappear without heat treatment — natural sunlight is enough" },
  { icon: "🛡", title: "Chemical Resistance", desc: "Protection against road salt, acid rain, and harsh winter conditions" },
  { icon: "✧", title: "Deep Gloss", desc: "Enhances paint depth and color vibrancy for a premium look" },
  { icon: "⏱", title: "7-Year Durability", desc: "Long-lasting protection that maintains clarity season after season" },
  { icon: "🔧", title: "Easy Installation", desc: "Elastic film that forgives positioning errors and conforms to any shape" },
  { icon: "🚫", title: "Anti-Yellowing", desc: "Advanced UV-resistant coating prevents yellowing over time" },
];

import { products } from "../data/products";

---

<BaseLayout title="KPPF.EU - Premium Paint Protection Film for Europe" description="Professional-grade polyurethane paint protection film with self-healing technology. Protect your vehicle with KPPF — designed for European roads.">

  <!-- Hero -->
  <section class="relative min-h-[90vh] flex items-center bg-kppf-black overflow-hidden">
    <!-- Video Background -->
    <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover opacity-50">
      <source src="/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-kppf-black via-kppf-black/80 to-kppf-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-kppf-black via-transparent to-kppf-black/50"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-3xl">
        <div id="hero-badge" class="inline-block bg-kppf-green/10 border border-kppf-green/30 rounded-full px-4 py-1.5 mb-8" style="opacity:0;transform:translateY(20px)">
          <span class="text-kppf-green text-sm font-medium">Now available in Europe</span>
        </div>
        
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.9] mb-8 font-head">
          <span id="hero-paint" class="block text-kppf-gray" style="opacity:0;transform:translateX(-200px)">PAINT</span>
          <span id="hero-protection" class="block text-kppf-green" style="opacity:0;transform:translateX(200px)">PROTECTION</span>
          <span id="hero-film" class="block text-kppf-gray" style="opacity:0;transform:translateX(-200px)">FILM</span>
        </h1>
        
        <p id="hero-desc" class="text-lg md:text-xl text-kppf-gray-300 mb-6 max-w-xl leading-relaxed" style="opacity:0;transform:translateY(20px)">
          Professional-grade polyurethane film with self-healing technology. Created by masters, for masters.
        </p>
        
        <div id="hero-promo" class="mb-10" style="opacity:0;transform:translateY(20px)"></div>
        
        <div id="hero-buttons" class="flex flex-col sm:flex-row gap-4" style="opacity:0;transform:translateY(20px)">
          <a href="/products" class="bg-kppf-green hover:bg-kppf-green-500 text-kppf-black px-8 py-4 rounded-xl text-lg font-semibold transition-all inline-flex items-center justify-center gap-2">
            View Products
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/contact" class="border border-kppf-gray-600 hover:border-kppf-green text-kppf-gray hover:text-kppf-green px-8 py-4 rounded-xl text-lg font-medium transition-all inline-flex items-center justify-center">
            Request Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Promo Marquee -->
  <div class="bg-kppf-green overflow-hidden py-3">
    <div class="promo-marquee">
      <div class="promo-scroll">
        {Array(12).fill(null).map(() => (
          <span class="inline-flex items-center gap-3 text-kppf-black font-bold text-sm tracking-wide whitespace-nowrap px-6">
            <span class="text-lg">★</span> 10% OFF YOUR FIRST ORDER
          </span>
        ))}
        {Array(12).fill(null).map(() => (
          <span class="inline-flex items-center gap-3 text-kppf-black font-bold text-sm tracking-wide whitespace-nowrap px-6">
            <span class="text-lg">★</span> 10% OFF YOUR FIRST ORDER
          </span>
        ))}
      </div>
    </div>
  </div>

  <style>
    .promo-marquee { overflow: hidden; }
    .promo-scroll {
      display: flex;
      width: max-content;
      animation: promo-slide 30s linear infinite;
    }
    @keyframes promo-slide {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <!-- Stats -->
  <section class="bg-kppf-gray-800 border-y border-kppf-gray-700/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-kppf-green font-head">190</div>
          <div class="text-kppf-gray-400 text-sm mt-1">μm thickness</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-kppf-green font-head">7</div>
          <div class="text-kppf-gray-400 text-sm mt-1">years warranty</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-kppf-green font-head">500%+</div>
          <div class="text-kppf-gray-400 text-sm mt-1">elongation</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-kppf-green font-head">15m</div>
          <div class="text-kppf-gray-400 text-sm mt-1">per roll</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 bg-kppf-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold font-head text-kppf-gray mb-4">Why Choose <span class="text-kppf-green">KPPF</span></h2>
        <p class="text-kppf-gray-400 max-w-2xl mx-auto">Advanced polyurethane technology engineered for maximum protection and longevity</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f) => (
          <div class="bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-2xl p-8 hover:border-kppf-green/30 transition-all group">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="text-lg font-semibold text-kppf-gray mb-2 group-hover:text-kppf-green transition-colors">{f.title}</h3>
            <p class="text-kppf-gray-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="py-20 bg-kppf-black-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold font-head text-kppf-gray mb-4">Our <span class="text-kppf-green">Products</span></h2>
        <p class="text-kppf-gray-400">Professional paint protection films for every need</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {products.map((p) => (
          <div class="bg-kppf-gray-800 rounded-2xl overflow-hidden border border-kppf-gray-700/50 hover:border-kppf-green/30 transition-all group">
            <div class="h-56 bg-kppf-gray-700 flex items-center justify-center relative overflow-hidden">
              <span class="absolute top-4 left-4 bg-kppf-green text-kppf-black text-xs font-bold px-3 py-1 rounded-full z-10">{p.tag}</span>
              <img src={p.img} alt={p.name} class="h-44 w-auto object-contain group-hover:scale-110 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-3">
                <h3 class="text-xl font-bold text-kppf-gray font-head">{p.name}</h3>
                <span class="text-kppf-green font-bold text-lg">€{p.price}</span>
              </div>
              <p class="text-kppf-gray-400 text-sm mb-2">{p.thickness} · {p.finish} · {p.size}</p>
              <p class="text-kppf-gray-300 text-sm mb-6 leading-relaxed">{p.shortDesc}</p>
              <a href={`/products/${p.slug}`} class="block bg-kppf-green hover:bg-kppf-green-500 text-kppf-black text-center py-3 rounded-xl font-semibold transition-all">
                View Details
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Visual Comparison Block -->
  <section class="py-24 bg-kppf-black relative overflow-hidden">
    <div class="absolute top-0 left-0 w-1/2 h-full bg-gradient-to-r from-kppf-green/[0.03] to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-kppf-green text-sm font-semibold tracking-widest uppercase mb-4 block">See The Difference</span>
        <h2 class="text-4xl md:text-5xl font-bold font-head text-kppf-gray leading-tight">
          One winter. <span class="text-kppf-green">Two outcomes.</span>
        </h2>
      </div>
      
      <div class="relative rounded-3xl overflow-hidden mb-12 border border-kppf-gray-700/50">
        <img src="/images/comparison-ppf.webp" alt="Before and after paint protection film — damaged paint vs pristine finish" class="w-full h-auto" loading="lazy" />
        <div class="absolute bottom-0 inset-x-0 flex">
          <div class="flex-1 bg-gradient-to-t from-black/80 to-transparent p-6 text-center">
            <span class="text-kppf-red font-bold text-lg font-head">WITHOUT PPF</span>
            <p class="text-kppf-gray-400 text-sm mt-1">Stone chips, yellowing, dull finish</p>
          </div>
          <div class="flex-1 bg-gradient-to-t from-black/80 to-transparent p-6 text-center">
            <span class="text-kppf-green font-bold text-lg font-head">WITH KPPF</span>
            <p class="text-kppf-gray-400 text-sm mt-1">Deep gloss, zero damage, like new</p>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="text-3xl md:text-4xl font-bold font-head text-kppf-gray leading-tight mb-8">
            Your car's paint <span class="text-kppf-green">loses 15% of its value</span> in the first year. Unless you protect it.
          </h3>
          <p class="text-kppf-gray-300 text-lg leading-relaxed mb-6">
            Stone chips, road salt, acid rain, UV exposure — European roads are brutal on automotive paint. A single winter can leave hundreds of micro-scratches that no wax or ceramic coating can prevent.
          </p>
          <p class="text-kppf-gray-300 text-lg leading-relaxed mb-8">
            KPPF paint protection film is the only barrier that physically absorbs the impact. At 190–240 microns thick, it's an invisible suit of armor that heals its own scratches — without heat, without effort, without compromise.
          </p>
          <div class="flex items-center gap-6">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-kppf-green/10 border border-kppf-green/30 flex items-center justify-center text-kppf-green text-xl">✓</div>
              <div><span class="text-kppf-gray font-semibold block">Proven</span><span class="text-kppf-gray-400 text-sm">7+ years of field testing</span></div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-kppf-green/10 border border-kppf-green/30 flex items-center justify-center text-kppf-green text-xl">✓</div>
              <div><span class="text-kppf-gray font-semibold block">Trusted</span><span class="text-kppf-gray-400 text-sm">1,000+ studios worldwide</span></div>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-3xl p-10 relative">
            <div class="absolute -top-4 -right-4 bg-kppf-green text-kppf-black text-xs font-bold px-4 py-2 rounded-full">FACT</div>
            <blockquote class="text-2xl md:text-3xl font-head text-kppf-gray leading-snug mb-6">
              "A scratch that would cost €800 to repaint disappears in 20 minutes of sunlight."
            </blockquote>
            <p class="text-kppf-gray-400 text-sm">KPPF self-healing technology — polyurethane memory restores the surface to its original state when exposed to heat from sunlight or warm water.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ogilvy Block 2: Social Proof / Authority -->
  <section class="py-20 bg-kppf-black-500">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-kppf-green text-sm font-semibold tracking-widest uppercase mb-4 block">Why professionals choose KPPF</span>
        <h2 class="text-3xl md:text-5xl font-bold font-head text-kppf-gray leading-tight">
          Created by <span class="text-kppf-green">installers</span>, not by marketers
        </h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-2xl p-8 relative group hover:border-kppf-green/30 transition-all">
          <div class="text-5xl font-head text-kppf-green/20 absolute top-4 right-6">01</div>
          <div class="text-4xl mb-6">🔬</div>
          <h3 class="text-xl font-bold text-kppf-gray mb-3 font-head">No-Heat Self-Healing</h3>
          <p class="text-kppf-gray-400 leading-relaxed">Most PPF brands require a heat gun to remove scratches. KPPF heals from ambient warmth alone — sunlight, body heat, even a cup of warm water. Less time per car. More cars per day.</p>
        </div>
        
        <div class="bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-2xl p-8 relative group hover:border-kppf-green/30 transition-all">
          <div class="text-5xl font-head text-kppf-green/20 absolute top-4 right-6">02</div>
          <div class="text-4xl mb-6">🖐️</div>
          <h3 class="text-xl font-bold text-kppf-gray mb-3 font-head">Forgives Your Mistakes</h3>
          <p class="text-kppf-gray-400 leading-relaxed">500%+ elongation means the film stretches where others tear. Reposition without damage. Wrap bumpers, mirrors, and deep curves in one piece. Your apprentice can work with it. Your master will love it.</p>
        </div>
        
        <div class="bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-2xl p-8 relative group hover:border-kppf-green/30 transition-all">
          <div class="text-5xl font-head text-kppf-green/20 absolute top-4 right-6">03</div>
          <div class="text-4xl mb-6">💰</div>
          <h3 class="text-xl font-bold text-kppf-gray mb-3 font-head">Better Margins</h3>
          <p class="text-kppf-gray-400 leading-relaxed">Premium quality at wholesale pricing. Full rolls only — no markup chains, no middlemen. Direct from the factory to your studio. The math is simple: lower material cost + faster installation = higher profit per job.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation / European roads visual -->
  <section class="py-20 bg-kppf-black relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative rounded-3xl overflow-hidden border border-kppf-gray-700/50">
          <img src="/images/self-healing-closeup.webp" alt="Professional PPF installation in a detailing studio" class="w-full h-auto" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-kppf-black/60 to-transparent"></div>
        </div>
        <div>
          <span class="text-kppf-green text-sm font-semibold tracking-widest uppercase mb-4 block">Built for European roads</span>
          <h2 class="text-3xl md:text-4xl font-bold font-head text-kppf-gray leading-tight mb-6">
            From Scandinavian frost to Mediterranean heat
          </h2>
          <p class="text-kppf-gray-300 text-lg leading-relaxed mb-6">
            European roads throw everything at your paint: Nordic salt and gravel, German Autobahn stone chips at 200 km/h, Mediterranean UV, and British acid rain. KPPF operates from -40°C to +80°C — it doesn't just survive these conditions, it thrives.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-kppf-gray-800/50 border border-kppf-gray-700/30 rounded-xl p-4">
              <div class="text-kppf-green font-head text-2xl mb-1">🇸🇪</div>
              <span class="text-kppf-gray text-sm font-semibold">Scandinavia</span>
              <p class="text-kppf-gray-400 text-xs mt-1">Salt, -30°C winters, gravel roads</p>
            </div>
            <div class="bg-kppf-gray-800/50 border border-kppf-gray-700/30 rounded-xl p-4">
              <div class="text-kppf-green font-head text-2xl mb-1">🇩🇪</div>
              <span class="text-kppf-gray text-sm font-semibold">Germany</span>
              <p class="text-kppf-gray-400 text-xs mt-1">Autobahn stone chips at speed</p>
            </div>
            <div class="bg-kppf-gray-800/50 border border-kppf-gray-700/30 rounded-xl p-4">
              <div class="text-kppf-green font-head text-2xl mb-1">🇮🇹</div>
              <span class="text-kppf-gray text-sm font-semibold">Mediterranean</span>
              <p class="text-kppf-gray-400 text-xs mt-1">Intense UV, +40°C heat</p>
            </div>
            <div class="bg-kppf-gray-800/50 border border-kppf-gray-700/30 rounded-xl p-4">
              <div class="text-kppf-green font-head text-2xl mb-1">🇬🇧</div>
              <span class="text-kppf-gray text-sm font-semibold">UK & Ireland</span>
              <p class="text-kppf-gray-400 text-xs mt-1">Rain, acid rain, constant moisture</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What KPPF solves: Without vs With -->
  <section class="py-20 bg-kppf-black-500">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold font-head text-kppf-gray">
          What <span class="text-kppf-green">KPPF</span> solves
        </h2>
        <p class="text-kppf-gray-400 mt-3">The real problems detailing professionals face — and how we fix them</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Without -->
        <div class="bg-kppf-gray-800 border border-kppf-red/20 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-kppf-red/10 rounded-full flex items-center justify-center text-kppf-red font-bold">✗</div>
            <h3 class="text-xl font-bold text-kppf-gray font-head">Without KPPF</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex gap-3 text-kppf-gray-400"><span class="text-kppf-red shrink-0">—</span>Complex installation, high risk of film damage</li>
            <li class="flex gap-3 text-kppf-gray-400"><span class="text-kppf-red shrink-0">—</span>Yellowing appears within months on white cars</li>
            <li class="flex gap-3 text-kppf-gray-400"><span class="text-kppf-red shrink-0">—</span>Needs extra treatment: wax, ceramic, polishing</li>
            <li class="flex gap-3 text-kppf-gray-400"><span class="text-kppf-red shrink-0">—</span>Customer complaints and expensive rework</li>
            <li class="flex gap-3 text-kppf-gray-400"><span class="text-kppf-red shrink-0">—</span>Slow installation = fewer cars per day</li>
          </ul>
        </div>
        
        <!-- With -->
        <div class="bg-kppf-gray-800 border border-kppf-green/20 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-kppf-green/10 rounded-full flex items-center justify-center text-kppf-green font-bold">✓</div>
            <h3 class="text-xl font-bold text-kppf-gray font-head">With KPPF</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex gap-3 text-kppf-gray-300"><span class="text-kppf-green shrink-0">+</span>Elastic film forgives positioning — fast, clean installs</li>
            <li class="flex gap-3 text-kppf-gray-300"><span class="text-kppf-green shrink-0">+</span>Anti-yellowing formula verified over 7 years</li>
            <li class="flex gap-3 text-kppf-gray-300"><span class="text-kppf-green shrink-0">+</span>No wax or ceramic needed — film does it all</li>
            <li class="flex gap-3 text-kppf-gray-300"><span class="text-kppf-green shrink-0">+</span>Zero complaints — self-healing handles minor damage</li>
            <li class="flex gap-3 text-kppf-gray-300"><span class="text-kppf-green shrink-0">+</span>Charge premium prices with higher margins</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Ogilvy Block 3: The Specifics (Numbers sell) -->
  <section class="py-24 bg-kppf-black relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-kppf-green text-sm font-semibold tracking-widest uppercase mb-4 block">By the numbers</span>
        <h2 class="text-3xl md:text-5xl font-bold font-head text-kppf-gray">
          Vague promises are cheap.<br/><span class="text-kppf-green">Here are the facts.</span>
        </h2>
      </div>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-gradient-to-b from-kppf-green/10 to-kppf-gray-800 border border-kppf-green/20 rounded-2xl p-8 text-center">
          <div class="text-5xl font-head text-kppf-green mb-3">240</div>
          <div class="text-kppf-gray font-semibold mb-2">microns max thickness</div>
          <p class="text-kppf-gray-400 text-sm">KPPF #99 — the thickest PPF on the market. That's a physical barrier no stone chip gets through.</p>
        </div>
        <div class="bg-gradient-to-b from-kppf-green/10 to-kppf-gray-800 border border-kppf-green/20 rounded-2xl p-8 text-center">
          <div class="text-5xl font-head text-kppf-green mb-3">500%</div>
          <div class="text-kppf-gray font-semibold mb-2">elongation before break</div>
          <p class="text-kppf-gray-400 text-sm">Stretch 5× its length without tearing. Complex curves, deep recesses, aggressive body lines — one piece, no seams.</p>
        </div>
        <div class="bg-gradient-to-b from-kppf-green/10 to-kppf-gray-800 border border-kppf-green/20 rounded-2xl p-8 text-center">
          <div class="text-5xl font-head text-kppf-green mb-3">-40°C</div>
          <div class="text-kppf-gray font-semibold mb-2">to +80°C operating range</div>
