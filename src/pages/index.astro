  <script is:inline>
    function animateHero() {
      const ease = 'cubic-bezier(0.16, 1, 0.3, 1)';
      
      function animate(id, delay, fromX, fromY) {
        setTimeout(() => {
          const el = document.getElementById(id);
          if (!el) return;
          el.style.transition = `opacity 0.8s ${ease}, transform 0.8s ${ease}`;
          el.style.opacity = '1';
          el.style.transform = 'translateX(0) translateY(0)';
        }, delay);
      }
      
      animate('hero-badge', 0, 0, 20);
      animate('hero-paint', 200, -200, 0);
      animate('hero-protection', 500, 200, 0);
      animate('hero-film', 800, -200, 0);
      animate('hero-desc', 1200, 0, 20);
      animate('hero-buttons', 1500, 0, 20);
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', animateHero);
    } else {
      animateHero();
    }
  </script>
