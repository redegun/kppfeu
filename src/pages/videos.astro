---
import BaseLayout from '../layouts/BaseLayout.astro';

const videos = [
  {
    title: "KPPF #24 on BMW M2 Competition — АВТОБАЗА К34",
    description: "Full installation test of KPPF #24 polyurethane film on a BMW M2 Competition. Watch the self-healing, elasticity, and finish quality in action.",
    category: "Installation",
    duration: "12:34",
    youtubeId: null,
  },
  {
    title: "KPPF #25 & #10 on Aito M9 — POLYGRAPH DETAILING",
    description: "Side-by-side installation test of two KPPF films on the Aito M9. Compare gloss, stretch, and healing performance.",
    category: "Installation",
    duration: "8:45",
    youtubeId: null,
  },
  {
    title: "KPPF #24 on Toyota Voxy — POLYGRAPH DETAILING",
    description: "Professional PPF application on a Toyota Voxy demonstrating how KPPF handles complex panels and curves.",
    category: "Installation",
    duration: "10:15",
    youtubeId: null,
  },
  {
    title: "KPPF #25 on Geely Monjaro — RWI Studio",
    description: "Real-world installation from RWI Studio. See how KPPF's 500%+ elongation handles the Monjaro's aggressive body lines.",
    category: "Installation",
    duration: "15:22",
    youtubeId: null,
  },
  {
    title: "KPPF #24 on Volkswagen Tiguan — TUNINGMONSTERS",
    description: "Complete front-end protection on a VW Tiguan. TUNINGMONSTERS team showcases clean installation technique.",
    category: "Installation",
    duration: "9:38",
    youtubeId: null,
  },
  {
    title: "KPPF #25 on Mini Cooper JCW — Creative Team Print",
    description: "Full wrap of a Mini Cooper JCW with KPPF #25. Compact body with tight curves — perfect test for film elasticity.",
    category: "Installation",
    duration: "11:50",
    youtubeId: null,
  },
  {
    title: "Self-Healing Technology — No Heat Required",
    description: "Watch scratches disappear in real time under natural sunlight. No heat gun, no effort — KPPF's polyurethane memory does the work.",
    category: "Technology",
    duration: "4:23",
    youtubeId: null,
  },
  {
    title: "KPPF PPF School — Ivan Chebotarev's Masterclass",
    description: "Professional training course by Ivan Chebotarev (VINIL52). Learn advanced PPF techniques and best practices with KPPF films.",
    category: "Education",
    duration: "22:18",
    youtubeId: null,
  },
];

const categories = ["All", "Installation", "Technology", "Education"];
---

<BaseLayout title="Videos - KPPF.EU Installation Guides & Demos" description="Watch professional PPF installation videos, self-healing demos, and training from certified KPPF installers across Europe.">

  <section class="py-20 bg-kppf-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold font-head mb-6">
          KPPF <span class="text-kppf-green">Videos</span>
        </h1>
        <p class="text-xl text-kppf-gray-300 max-w-3xl mx-auto mb-10">
          Real installations, real studios, real results. Watch how professionals work with KPPF films.
        </p>
        
        <!-- Category Filter -->
        <div class="flex flex-wrap justify-center gap-3">
          {categories.map(cat => (
            <button 
              class={`cat-btn px-5 py-2 rounded-full text-sm font-medium transition-all ${
                cat === 'All' 
                  ? 'bg-kppf-green text-kppf-black' 
                  : 'bg-kppf-gray-800 border border-kppf-gray-700/50 text-kppf-gray-300 hover:border-kppf-green/30 hover:text-kppf-green'
              }`}
              data-cat={cat.toLowerCase()}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      <!-- Videos Grid -->
      <div id="vgrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map((v, i) => (
          <div class="video-item bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-2xl overflow-hidden hover:border-kppf-green/30 transition-all group" data-cat={v.category.toLowerCase()}>
            <!-- Thumbnail -->
            <div class="relative h-52 bg-kppf-gray-700 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-kppf-green/10 to-kppf-black/40 flex items-center justify-center">
                <div class="w-16 h-16 bg-kppf-green/90 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg shadow-kppf-green/20">
                  <svg class="w-7 h-7 text-kppf-black ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              <div class="absolute bottom-3 right-3 bg-kppf-black/70 text-kppf-gray px-2.5 py-1 rounded-lg text-xs font-medium backdrop-blur-sm">{v.duration}</div>
              <div class="absolute top-3 left-3 bg-kppf-green text-kppf-black text-xs font-bold px-3 py-1 rounded-full">{v.category}</div>
            </div>
            
            <!-- Info -->
            <div class="p-5">
              <h3 class="text-lg font-semibold text-kppf-gray mb-2 group-hover:text-kppf-green transition-colors line-clamp-2">{v.title}</h3>
              <p class="text-kppf-gray-400 text-sm leading-relaxed line-clamp-3">{v.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Coming Soon Note -->
      <div class="mt-16 text-center">
        <div class="inline-block bg-kppf-gray-800 border border-kppf-gray-700/50 rounded-2xl px-8 py-6">
          <p class="text-kppf-gray-300 mb-2">🎬 Video embeds coming soon — full library in production</p>
          <p class="text-kppf-gray-500 text-sm">Want early access? <a href="/contact" class="text-kppf-green hover:underline">Contact us</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Test Roll CTA -->
  <section class="py-24 bg-kppf-black-500 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-kppf-green/[0.04] via-transparent to-kppf-green/[0.02]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="relative rounded-3xl overflow-hidden border border-kppf-green/20 shadow-2xl shadow-kppf-green/5">
          <img src="/images/kppf-box-studio.webp" alt="KPPF product box in a professional detailing studio" class="w-full h-auto" loading="lazy" />
          <div class="absolute top-4 left-4 bg-kppf-green text-kppf-black text-xs font-bold px-4 py-2 rounded-full uppercase tracking-wider">Free test roll</div>
        </div>
        <div>
          <span class="text-kppf-green text-sm font-semibold tracking-widest uppercase mb-4 block">For detailing studios & vinyl shops</span>
          <h2 class="text-4xl md:text-5xl font-bold font-head text-kppf-gray leading-tight mb-6">
            Seen enough?<br/><span class="text-kppf-green">Try it yourself.</span>
          </h2>
          <p class="text-kppf-gray-300 text-lg leading-relaxed mb-4">
            Videos are great, but nothing beats feeling the film in your own hands. Request a free test roll — stretch it, heal it, install it on a real car.
          </p>
          <p class="text-kppf-gray-300 text-lg leading-relaxed mb-8">
            No commitments. If it's not the best film you've worked with, you owe us nothing.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-kppf-gray-300">
              <span class="w-6 h-6 bg-kppf-green/10 border border-kppf-green/30 rounded-full flex items-center justify-center text-kppf-green text-xs">✓</span>
              Available for registered detailing studios
            </li>
            <li class="flex items-center gap-3 text-kppf-gray-300">
              <span class="w-6 h-6 bg-kppf-green/10 border border-kppf-green/30 rounded-full flex items-center justify-center text-kppf-green text-xs">✓</span>
              Shipped free across Europe
            </li>
            <li class="flex items-center gap-3 text-kppf-gray-300">
              <span class="w-6 h-6 bg-kppf-green/10 border border-kppf-green/30 rounded-full flex items-center justify-center text-kppf-green text-xs">✓</span>
              Full-size sample — enough for a real installation test
            </li>
          </ul>
          <a href="/contact" class="inline-flex items-center gap-2 bg-kppf-green hover:bg-kppf-green-500 text-kppf-black px-8 py-4 rounded-xl text-lg font-semibold transition-all">
            Request a Test Roll
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-kppf-green">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold font-head text-kppf-black mb-4">Want to See KPPF on Your Car?</h2>
      <p class="text-kppf-black/70 text-lg mb-8">Find a certified installer near you or become a KPPF partner.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-kppf-black hover:bg-kppf-black-500 text-kppf-green font-semibold py-3 px-8 rounded-xl transition-all">Contact Us</a>
        <a href="/products" class="bg-kppf-black/10 hover:bg-kppf-black/20 text-kppf-black font-semibold py-3 px-8 rounded-xl transition-all">View Products</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.cat-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.cat;
        document.querySelectorAll('.cat-btn').forEach(b => {
          b.classList.remove('bg-kppf-green', 'text-kppf-black');
          b.classList.add('bg-kppf-gray-800', 'text-kppf-gray-300');
        });
        btn.classList.remove('bg-kppf-gray-800', 'text-kppf-gray-300');
        btn.classList.add('bg-kppf-green', 'text-kppf-black');
        document.querySelectorAll('.video-item').forEach(v => {
          v.style.display = (cat === 'all' || v.dataset.cat === cat) ? '' : 'none';
        });
      });
    });
  </script>

  <style>
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  </style>
</BaseLayout>
