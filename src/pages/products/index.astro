---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Products - KPPF.EU Premium Paint Protection Film" description="Browse our range of premium paint protection films. KPPF #24, #25, and #10 - engineered for European market with self-healing technology.">
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-kppf-gray mb-6">
          Our <span class="text-kppf-green">Products</span>
        </h1>
        <p class="text-xl text-kppf-gray-300 mb-8 max-w-3xl mx-auto">
          Professional-grade paint protection films engineered for the European market. 
          Choose the perfect protection level for your vehicle.
        </p>
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="py-20 bg-kppf-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Product Categories Info -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-16">
        <div class="bg-kppf-gray-700/50 p-6 rounded-xl border border-kppf-gray-600">
          <h3 class="text-lg font-semibold text-kppf-green mb-2">Premium Line</h3>
          <p class="text-kppf-gray-400">Maximum protection with advanced features for luxury and high-performance vehicles.</p>
        </div>
        <div class="bg-kppf-gray-700/50 p-6 rounded-xl border border-kppf-gray-600">
          <h3 class="text-lg font-semibold text-kppf-green mb-2">Professional Grade</h3>
          <p class="text-kppf-gray-400">Balanced performance and value for professional installation and daily driving.</p>
        </div>
        <div class="bg-kppf-gray-700/50 p-6 rounded-xl border border-kppf-gray-600">
          <h3 class="text-lg font-semibold text-kppf-green mb-2">Economy Line</h3>
          <p class="text-kppf-gray-400">Essential protection at an accessible price point without compromising quality.</p>
        </div>
      </div>

      <!-- Products Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- KPPF #24 -->
        <div class="bg-gradient-to-br from-gray-800 to-gray-700 rounded-xl overflow-hidden shadow-2xl hover:shadow-kppf-green/20 transition-all transform hover:scale-105">
          <div class="h-64 bg-gradient-to-br from-amber-400 to-amber-600 relative">
            <div class="absolute top-4 left-4 bg-kppf-green text-kppf-gray px-3 py-1 rounded-full text-sm font-semibold">
              Premium
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold text-kppf-gray mb-2">KPPF #24</h3>
            <p class="text-kppf-green font-bold text-xl mb-4">€890 per roll</p>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                190μm thickness
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                15m × 1.52m roll
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Self-healing without heat
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Anti-yellowing technology
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Deep gloss finish
              </div>
            </div>
            
            <div class="flex gap-2">
              <a href="/products/kppf-24" class="flex-1 bg-gray-600 hover:bg-gray-500 text-kppf-gray text-center py-3 rounded-lg font-semibold transition-colors">
                View Details
              </a>
              <button 
                onclick="addToCart('kppf-24', 'KPPF #24', 890, '/images/kppf-24.jpg')"
                class="flex-1 bg-kppf-green hover:bg-kppf-green-500 text-kppf-gray py-3 rounded-lg font-semibold transition-colors"
              >
                Add to Cart
              </button>
            </div>
          </div>
        </div>

        <!-- KPPF #25 -->
        <div class="bg-gradient-to-br from-gray-800 to-gray-700 rounded-xl overflow-hidden shadow-2xl hover:shadow-kppf-green/20 transition-all transform hover:scale-105">
          <div class="h-64 bg-gradient-to-br from-blue-400 to-blue-600 relative">
            <div class="absolute top-4 left-4 bg-blue-600 text-kppf-gray px-3 py-1 rounded-full text-sm font-semibold">
              Enhanced
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold text-kppf-gray mb-2">KPPF #25</h3>
            <p class="text-kppf-green font-bold text-xl mb-4">€990 per roll</p>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                200μm thickness
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                15m × 1.52m roll
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Enhanced protection
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Ideal for dark vehicles
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Premium performance
              </div>
            </div>
            
            <div class="flex gap-2">
              <a href="/products/kppf-25" class="flex-1 bg-gray-600 hover:bg-gray-500 text-kppf-gray text-center py-3 rounded-lg font-semibold transition-colors">
                View Details
              </a>
              <button 
                onclick="addToCart('kppf-25', 'KPPF #25', 990, '/images/kppf-25.jpg')"
                class="flex-1 bg-kppf-green hover:bg-kppf-green-500 text-kppf-gray py-3 rounded-lg font-semibold transition-colors"
              >
                Add to Cart
              </button>
            </div>
          </div>
        </div>

        <!-- KPPF #10 -->
        <div class="bg-gradient-to-br from-gray-800 to-gray-700 rounded-xl overflow-hidden shadow-2xl hover:shadow-kppf-green/20 transition-all transform hover:scale-105">
          <div class="h-64 bg-gradient-to-br from-green-400 to-green-600 relative">
            <div class="absolute top-4 left-4 bg-kppf-green text-kppf-gray px-3 py-1 rounded-full text-sm font-semibold">
              Economy
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-2xl font-bold text-kppf-gray mb-2">KPPF #10</h3>
            <p class="text-kppf-green font-bold text-xl mb-4">€690 per roll</p>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                160μm thickness
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                15m × 1.52m roll
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Economy line
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Good basic protection
              </div>
              <div class="flex items-center text-kppf-gray-300">
                <svg class="w-4 h-4 mr-2 text-kppf-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Value for money
              </div>
            </div>
            
            <div class="flex gap-2">
              <a href="/products/kppf-10" class="flex-1 bg-gray-600 hover:bg-gray-500 text-kppf-gray text-center py-3 rounded-lg font-semibold transition-colors">
                View Details
              </a>
              <button 
                onclick="addToCart('kppf-10', 'KPPF #10', 690, '/images/kppf-10.jpg')"
                class="flex-1 bg-kppf-green hover:bg-kppf-green-500 text-kppf-gray py-3 rounded-lg font-semibold transition-colors"
              >
                Add to Cart
              </button>
            </div>
          </div>
        </div>

      </div>

      <!-- Additional Info -->
      <div class="mt-16 bg-kppf-gray-700/30 rounded-xl p-8">
        <h3 class="text-2xl font-bold text-kppf-gray mb-6 text-center">Why Choose KPPF?</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="w-12 h-12 bg-kppf-green rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-kppf-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-kppf-gray mb-2">7-Year Warranty</h4>
            <p class="text-kppf-gray-400">Comprehensive protection guarantee</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-kppf-green rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-kppf-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-kppf-gray mb-2">Fast Delivery</h4>
            <p class="text-kppf-gray-400">Quick shipping across Europe</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-kppf-green rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-kppf-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-kppf-gray mb-2">Expert Support</h4>
            <p class="text-kppf-gray-400">Professional installation guidance</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-kppf-green rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-kppf-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-kppf-gray mb-2">Premium Quality</h4>
            <p class="text-kppf-gray-400">European tested and certified</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center">
        <h3 class="text-2xl font-bold text-kppf-gray mb-4">Need Help Choosing?</h3>
        <p class="text-kppf-gray-400 mb-8">Our experts are here to help you select the perfect protection for your vehicle.</p>
        <a href="/contact" class="bg-kppf-green hover:bg-kppf-green-500 text-kppf-gray px-8 py-3 rounded-lg font-semibold transition-colors">
          Contact Our Experts
        </a>
      </div>

    </div>
  </section>

  <script>
    function addToCart(id, name, price, image) {
      const cart = JSON.parse(localStorage.getItem('kppf-cart') || '[]');
      const existingItem = cart.find(item => item.id === id);
      
      if (existingItem) {
        existingItem.quantity += 1;
      } else {
        cart.push({ id, name, price, image, quantity: 1 });
      }
      
      localStorage.setItem('kppf-cart', JSON.stringify(cart));
      
      // Trigger cart update event
      window.dispatchEvent(new Event('cart-updated'));
      
      // Show feedback
      const button = event.target;
      const originalText = button.textContent;
      button.textContent = 'Added!';
      button.classList.add('bg-kppf-green');
      
      setTimeout(() => {
        button.textContent = originalText;
        button.classList.remove('bg-kppf-green');
      }, 1000);
    }
  </script>

</BaseLayout>