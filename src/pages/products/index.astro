---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';
---

<BaseLayout title="Products - KPPF.EU Premium Paint Protection Film" description="Browse KPPF paint protection films: #24, #84, #96, #99. From satin to max thickness. Engineered for European professionals.">
  <section class="py-20 bg-kppf-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold font-head mb-6">Our <span class="text-kppf-green">Products</span></h1>
        <p class="text-xl text-kppf-gray-300 max-w-3xl mx-auto">Professional-grade paint protection films. Four unique formulations for every need. Full rolls only.</p>
      </div>

      <div class="space-y-8">
        {products.map((p) => (
          <div class="bg-kppf-gray-800 rounded-2xl border border-kppf-gray-700/50 overflow-hidden hover:border-kppf-green/30 transition-all">
            <div class="grid md:grid-cols-3 gap-0">
              <div class="bg-kppf-gray-700 flex items-center justify-center p-8">
                <img src={p.img} alt={p.name} class="h-48 w-auto object-contain" />
              </div>
              <div class="md:col-span-2 p-8">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <span class="inline-block bg-kppf-green/10 text-kppf-green text-xs font-semibold px-3 py-1 rounded-full mb-2">{p.tag}</span>
                    <h2 class="text-2xl font-bold font-head">{p.name}</h2>
                  </div>
                  <div class="text-right">
                    <div class="text-2xl font-bold text-kppf-green">€{p.price}</div>
                    <div class="text-kppf-gray-500 text-sm">per roll</div>
                  </div>
                </div>
                <p class="text-kppf-gray-300 mb-4">{p.shortDesc}</p>
                <div class="flex flex-wrap gap-3 mb-4 text-sm">
                  <span class="bg-kppf-gray-700 px-3 py-1 rounded-lg text-kppf-gray-300">{p.thickness}</span>
                  <span class="bg-kppf-gray-700 px-3 py-1 rounded-lg text-kppf-gray-300">{p.finish}</span>
                  <span class="bg-kppf-gray-700 px-3 py-1 rounded-lg text-kppf-gray-300">{p.color}</span>
                  <span class="bg-kppf-gray-700 px-3 py-1 rounded-lg text-kppf-gray-300">{p.size}</span>
                </div>
                <div class="flex flex-wrap gap-x-4 gap-y-1 mb-6">
                  {p.features.slice(0, 4).map((f) => (
                    <span class="text-kppf-gray-400 text-sm flex items-center gap-1">
                      <span class="text-kppf-green">✓</span> {f.split('—')[0].trim()}
                    </span>
                  ))}
                </div>
                <a href={`/products/${p.slug}`} class="inline-block bg-kppf-green hover:bg-kppf-green-500 text-kppf-black font-semibold px-6 py-3 rounded-xl transition-all">
                  View Details & Order
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-kppf-gray-800 border-t border-kppf-gray-700/30">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold font-head mb-4">Need Help Choosing?</h2>
      <p class="text-kppf-gray-400 mb-8">Contact us for expert advice on which KPPF film is right for your application.</p>
      <a href="/contact" class="inline-block border border-kppf-green text-kppf-green hover:bg-kppf-green hover:text-kppf-black font-semibold px-8 py-3 rounded-xl transition-all">
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
