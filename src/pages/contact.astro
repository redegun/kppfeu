---
import BaseLayout from "../layouts/BaseLayout.astro";

const team = [
  {
    name: "Nikolai",
    role: "Head of Sales & Partnerships",
    photo: "/images/nikolai.webp",
    bio: "10+ years in the automotive aftermarket industry. Nikolai oversees all B2B relationships, distributor agreements, and wholesale pricing for the European market.",
    whatsapp: "https://wa.me/46701234567",
    telegram: "https://t.me/kppf_nikolai",
    facebook: "https://facebook.com/kppf.eu",
    email: "nikolai@kppf.eu",
  },
  {
    name: "Gleb",
    role: "Technical Director & Product Specialist",
    photo: "/images/gleb.webp",
    bio: "Film engineering background with hands-on detailing experience. Gleb handles technical questions, installation support, and product training for new partners across Europe.",
    whatsapp: "https://wa.me/46709876543",
    telegram: "https://t.me/kppf_gleb",
    facebook: "https://facebook.com/kppf.eu",
    email: "gleb@kppf.eu",
  },
];
---

<BaseLayout title="Contact Us - KPPF.EU" description="Get in touch with KPPF Europe. Order paint protection film or become a partner.">
  <section class="py-20 bg-kppf-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold font-head mb-6">Get in <span class="text-kppf-green">Touch</span></h1>
        <p class="text-xl text-kppf-gray-300 max-w-2xl mx-auto">Have questions? Want to place an order or become a partner? Reach out to our European team directly.</p>
      </div>

      <!-- Team -->
      <div class="grid md:grid-cols-2 gap-8 mb-16">
        {team.map((person) => (
          <div class="bg-kppf-gray-800 rounded-2xl border border-kppf-gray-700/50 overflow-hidden hover:border-kppf-green/30 transition-all">
            <div class="flex flex-col sm:flex-row">
              <div class="sm:w-40 shrink-0">
                <img src={person.photo} alt={person.name} class="w-full h-48 sm:h-full object-cover" />
              </div>
              <div class="p-6 flex-1">
                <h3 class="text-xl font-bold text-kppf-gray font-head">{person.name}</h3>
                <p class="text-kppf-green text-sm font-medium mb-3">{person.role}</p>
                <p class="text-kppf-gray-400 text-sm leading-relaxed mb-4">{person.bio}</p>
                <div class="flex flex-wrap gap-2">
                  <a href={person.whatsapp} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 bg-[#25D366]/10 border border-[#25D366]/30 text-[#25D366] text-xs font-medium px-3 py-1.5 rounded-full hover:bg-[#25D366]/20 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                  </a>
                  <a href={person.telegram} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 bg-[#26A5E4]/10 border border-[#26A5E4]/30 text-[#26A5E4] text-xs font-medium px-3 py-1.5 rounded-full hover:bg-[#26A5E4]/20 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                    Telegram
                  </a>
                  <a href={person.facebook} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 bg-[#1877F2]/10 border border-[#1877F2]/30 text-[#1877F2] text-xs font-medium px-3 py-1.5 rounded-full hover:bg-[#1877F2]/20 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    Facebook
                  </a>
                  <a href={`mailto:${person.email}`} class="inline-flex items-center gap-1.5 bg-kppf-green/10 border border-kppf-green/30 text-kppf-green text-xs font-medium px-3 py-1.5 rounded-full hover:bg-kppf-green/20 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Email
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Form -->
        <div class="bg-kppf-gray-800 rounded-2xl p-8 border border-kppf-gray-700/50">
          <h2 class="text-xl font-bold font-head mb-6 text-kppf-green">Send a Message</h2>
          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-kppf-gray-300 mb-2">Name *</label>
              <input type="text" id="name" name="name" required class="w-full bg-kppf-gray-700 border border-kppf-gray-600 rounded-xl px-4 py-3 text-kppf-gray placeholder-kppf-gray-500 focus:ring-2 focus:ring-kppf-green focus:border-transparent transition outline-none" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-kppf-gray-300 mb-2">Email *</label>
              <input type="email" id="email" name="email" required class="w-full bg-kppf-gray-700 border border-kppf-gray-600 rounded-xl px-4 py-3 text-kppf-gray placeholder-kppf-gray-500 focus:ring-2 focus:ring-kppf-green focus:border-transparent transition outline-none" placeholder="your@email.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-kppf-gray-300 mb-2">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full bg-kppf-gray-700 border border-kppf-gray-600 rounded-xl px-4 py-3 text-kppf-gray placeholder-kppf-gray-500 focus:ring-2 focus:ring-kppf-green focus:border-transparent transition outline-none" placeholder="+46 ..." />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-kppf-gray-300 mb-2">Message *</label>
              <textarea id="message" name="message" rows="4" required class="w-full bg-kppf-gray-700 border border-kppf-gray-600 rounded-xl px-4 py-3 text-kppf-gray placeholder-kppf-gray-500 focus:ring-2 focus:ring-kppf-green focus:border-transparent transition resize-none outline-none" placeholder="Tell us about your needs..."></textarea>
            </div>
            <button type="submit" class="w-full bg-kppf-green hover:bg-kppf-green-500 text-kppf-black font-semibold py-3 px-6 rounded-xl transition-all">Send Message</button>
          </form>
          <div id="form-success" class="hidden mt-6 p-4 bg-kppf-green/10 border border-kppf-green/30 rounded-xl text-kppf-green text-center">
            ✅ Thank you! We'll get back to you shortly.
          </div>
        </div>

        <!-- Info -->
        <div class="space-y-6">
          <div class="bg-kppf-gray-800 rounded-2xl p-8 border border-kppf-gray-700/50">
            <h2 class="text-xl font-bold font-head mb-6 text-kppf-green">Contact Information</h2>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <span class="text-xl">📍</span>
                <div>
                  <h3 class="font-semibold text-sm mb-1">Address</h3>
                  <p class="text-kppf-gray-400 text-sm">Drottninggatan 55<br>111 21 Stockholm, Sweden</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="text-xl">📧</span>
                <div>
                  <h3 class="font-semibold text-sm mb-1">Email</h3>
                  <a href="mailto:info@kppf.eu" class="text-kppf-green hover:text-kppf-green-500 text-sm transition-colors">info@kppf.eu</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="text-xl">📞</span>
                <div>
                  <h3 class="font-semibold text-sm mb-1">Phone</h3>
                  <a href="tel:+4681234567" class="text-kppf-green hover:text-kppf-green-500 text-sm transition-colors">+46 8 123 45 67</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Social -->
          <div class="bg-kppf-gray-800 rounded-2xl p-8 border border-kppf-gray-700/50">
            <h2 class="text-xl font-bold font-head mb-4 text-kppf-green">Follow Us</h2>
            <div class="flex gap-3">
              <a href="https://wa.me/46701234567" target="_blank" rel="noopener" class="w-12 h-12 bg-[#25D366]/10 border border-[#25D366]/30 rounded-xl flex items-center justify-center text-[#25D366] hover:bg-[#25D366]/20 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
              <a href="https://t.me/kppf_eu" target="_blank" rel="noopener" class="w-12 h-12 bg-[#26A5E4]/10 border border-[#26A5E4]/30 rounded-xl flex items-center justify-center text-[#26A5E4] hover:bg-[#26A5E4]/20 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              </a>
              <a href="https://facebook.com/kppf.eu" target="_blank" rel="noopener" class="w-12 h-12 bg-[#1877F2]/10 border border-[#1877F2]/30 rounded-xl flex items-center justify-center text-[#1877F2] hover:bg-[#1877F2]/20 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            </div>
          </div>

          <div class="bg-kppf-gray-800 rounded-2xl p-8 border border-kppf-gray-700/50">
            <h2 class="text-xl font-bold font-head mb-4 text-kppf-green">Business Hours</h2>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-kppf-gray-400">Monday – Friday</span><span>9:00 – 18:00</span></div>
              <div class="flex justify-between"><span class="text-kppf-gray-400">Saturday</span><span>10:00 – 15:00</span></div>
              <div class="flex justify-between"><span class="text-kppf-gray-400">Sunday</span><span class="text-kppf-gray-500">Closed</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('contact-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const data = Object.fromEntries(new FormData(form));
      console.log('Contact form submitted:', data);
      form.classList.add('hidden');
      document.getElementById('form-success')?.classList.remove('hidden');
    });
  </script>
</BaseLayout>
